{
  "name": "luogu-solution-wiki",
  "version": "1.0.0",
  "description": "洛谷风格题解网站 - 支持GitHub Pages静态部署",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "node scripts/build-static.js && vite build",
    "build:static": "node scripts/build-static.js && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "express": "^4.18.2",
    "chokidar": "^3.5.3",
    "gray-matter": "^4.0.3",
    "marked": "^11.0.0",
    "highlight.js": "^11.9.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}